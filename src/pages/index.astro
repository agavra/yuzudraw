---
import Layout from '../layouts/Layout.astro';

const res = await fetch('https://api.github.com/repos/agavra/yuzudraw');
const data = await res.json();
const stars = (data.stargazers_count ?? 0).toLocaleString();
---

<Layout title="YuzuDraw">
  <!-- Topbar -->
  <nav class="sticky top-0 z-50 bg-white/80 backdrop-blur-lg border-b border-gray-100">
    <div class="px-6 h-14 flex items-center justify-between gap-4">
      <div class="flex items-center gap-8">
        <a href="#top" class="flex items-center gap-2 text-gray-700 no-underline text-xl tracking-tight">
          <img src="/yuzudraw-icon.svg" alt="" class="h-7" />
          <span><span class="font-extralight">yuzu</span><span class="font-bold">draw</span></span>
        </a>
        <div class="hidden items-center gap-6 font-mono text-sm font-semibold text-gray-500 md:flex">
          <a href="#features" class="transition-colors duration-200 hover:text-brand">features</a>
          <a href="#quickstart" class="transition-colors duration-200 hover:text-brand">quickstart</a>
        </div>
      </div>
      <a href="https://github.com/agavra/yuzudraw" target="_blank" rel="noopener" class="flex items-center gap-1.5 text-gray-400 hover:text-gray-900 border border-gray-200 rounded-full px-2.5 py-1 transition-colors" aria-label="GitHub">
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
          <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
        </svg>
        <span class="text-xs flex items-center gap-0.5">
          <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 16 16">
            <path d="M8 .25a.75.75 0 01.673.418l1.882 3.815 4.21.612a.75.75 0 01.416 1.279l-3.046 2.97.719 4.192a.75.75 0 01-1.088.791L8 12.347l-3.766 1.98a.75.75 0 01-1.088-.79l.72-4.194L.818 6.374a.75.75 0 01.416-1.28l4.21-.611L7.327.668A.75.75 0 018 .25z"/>
          </svg>
          {stars}
        </span>
      </a>
    </div>
  </nav>

  <main id="top">
    <!-- Hero -->
    <section class="overflow-x-clip pt-24 pb-32 text-center px-6">
      <div class="max-w-3xl mx-auto">
        <h1 class="inline-block max-w-full border-2 border-gray-900 px-5 py-4 text-[clamp(1.75rem,6vw,2.75rem)] font-mono font-bold tracking-tight leading-[1.05] mb-6 text-balance sm:px-8">
          beautiful ascii diagrams
        </h1>
        <p class="text-lg text-gray-500 max-w-2xl mx-auto mb-10 leading-relaxed">
          A macOS-native ASCII diagram editor with an agent skill.
          Let Codex or Claude generate your diagrams, then refine them on a visual canvas.
        </p>
        <div class="flex flex-col items-center justify-center gap-3 sm:flex-row">
          <a href="https://github.com/agavra/yuzudraw/releases/latest/download/YuzuDraw-universal.dmg" class="inline-block px-8 py-3.5 bg-black text-white font-semibold rounded-none shadow-sm hover:bg-brand-light hover:-translate-y-0.5 transition-all duration-200">
            <svg class="inline-block w-4 h-4 -mt-1.5 mr-1.5 align-middle" viewBox="0 0 814 1000" fill="currentColor"><path d="M788.1 340.9c-5.8 4.5-108.2 62.2-108.2 190.5 0 148.4 130.3 200.9 134.2 202.2-.6 3.2-20.7 71.9-68.7 141.9-42.8 61.6-87.5 123.1-155.5 123.1s-85.5-39.5-164-39.5c-76.5 0-103.7 40.8-165.9 40.8s-105.6-57.8-155.5-127.4c-58.4-81.8-105.9-209.2-105.9-330.8 0-194.3 126.4-297.5 250.8-297.5 66.1 0 121.2 43.4 162.7 43.4 39.5 0 101.1-46 176.3-46 28.5 0 130.9 2.6 198.3 99.2zm-234-181.5c31.1-36.9 53.1-88.1 53.1-139.3 0-7.1-.6-14.3-1.9-20.1-50.6 1.9-110.8 33.7-147.1 75.8-28.5 32.4-55.1 83.6-55.1 135.5 0 7.8.7 15.6 1.3 18.1 2.6.5 6.5.5 10.4.5 45.9 0 104-30.4 139.3-70.5z"/></svg>
            Download for Mac
          </a>
          <a href="https://github.com/agavra/yuzudraw" target="_blank" rel="noopener" class="inline-flex items-center justify-center gap-2 border border-gray-300 bg-white px-8 py-3.5 font-semibold text-gray-900 shadow-sm transition-all duration-200 hover:-translate-y-0.5 hover:border-brand">
            <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M12 0C5.373 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.304-5.467-1.334-5.467-5.93 0-1.312.469-2.382 1.236-3.222-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.49 11.49 0 0 1 12 5.8c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.91 1.235 3.222 0 4.607-2.805 5.625-5.475 5.921.43.372.813 1.103.813 2.222v3.293c0 .319.192.694.8.576C20.565 21.795 24 17.298 24 12c0-6.627-5.373-12-12-12Z" />
            </svg>
            <span>View on GitHub</span>
          </a>
        </div>
        <div class="mt-4">
          <a href="#quickstart" data-scroll-to="quickstart" class="inline-flex items-center gap-2 font-mono text-sm font-semibold text-gray-500 hover:text-brand transition-colors duration-200">
            <span>jump to quickstart</span>
            <span aria-hidden="true">↓</span>
          </a>
        </div>
      </div>
    </section>

    <!-- Primary screenshot -->
    <section class="pb-20 px-6">
      <div class="max-w-6xl mx-auto rounded-xl overflow-hidden">
        <img src="/screenshot-claude.png" alt="Agent generating a diagram via YuzuDraw CLI" class="block w-full h-auto" />
      </div>
    </section>

    <!-- Canvas details -->
    <section class="relative border-t border-gray-100 overflow-hidden">
      <div class="absolute inset-0 canvas-grid"></div>
      <div class="relative py-24 px-3 sm:px-6">
        <div class="max-w-6xl mx-auto">
          <div id="features" class="max-w-3xl mb-12 scroll-mt-24">
            <h2 class="inline-block text-2xl font-mono font-bold mb-3 border border-dashed border-gray-300 px-4 py-2 bg-white">From Prompt to Canvas</h2>
          </div>

          <div class="border border-gray-300 bg-white p-4 sm:p-8">
              <div class="mb-8">
                <div class="mb-3">
                  <div class="font-mono text-sm font-bold text-brand mb-2 tracking-wide">/draw</div>
                  <h3 class="inline-block text-xl font-mono font-semibold border border-dashed border-gray-300 px-3 py-1">Skill Examples</h3>
                </div>
                <p class="text-sm text-gray-500 leading-relaxed max-w-2xl">
                  The unified skill spans structural diagrams, process flow, metric comparison, and small terminal art without switching tools or modes.
                </p>
              </div>

              <div class="overflow-hidden" data-draw-carousel>
                <div class="overflow-x-auto overscroll-x-contain snap-x snap-mandatory scrollbar-hide" data-draw-carousel-viewport>
                  <div class="flex gap-0 sm:gap-6 sm:px-0" data-draw-carousel-container>
                <div class="min-w-0 w-full flex-[0_0_100%] snap-center sm:max-w-[30rem] sm:flex-[0_0_30rem] xl:max-w-[34rem] xl:flex-[0_0_34rem] border border-gray-300 p-3 sm:p-5 bg-gray-50">
                  <div class="text-brand font-bold mb-3">components</div>
                  <p class="text-xs text-gray-500 mb-3 leading-relaxed">Map internal structure, service boundaries, and dependencies.</p>
                  <pre class="bg-white border border-gray-200 px-4 py-3 overflow-x-auto text-xs leading-relaxed mb-3"><code>/draw a component diagram for a search node with client traffic, planning modules, segment stores, shared cache, and object storage</code></pre>
                  <pre class="bg-black text-white border border-black px-4 py-3 overflow-x-auto text-[9px] leading-tight"><code>
      ╭────────╮
      │ Client │
      ╰────┬───╯
╔══════════╪═══════════════════════════════════════╗
║          │                                       ║░
║     ╭────▼───╮    ╭──────────╮     ╭────────╮    ║░
║     │  API   ├────▶ Planner  ├─────▶ Router │    ║░
║     ╰────┬───╯    ╰─────┬────╯     ╰────┬───╯    ║░
║          └──┐          ┌┘         ┌─────┘        ║░
║             │          │          │              ║░
║         ┌───▼──┐   ┌───▼──┐   ┌───▼──┐           ║░
║         │██████│   │██████│   │██████│           ║░
║         └──────┘   └──────┘   └──────┘           ║░
║          seg A      seg B      seg C             ║░
║                                                  ║░
╚════════════════shared cache══════════════════════╝░
 ░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░</code></pre>
                </div>
                <div class="min-w-0 w-full flex-[0_0_100%] snap-center sm:max-w-[30rem] sm:flex-[0_0_30rem] xl:max-w-[34rem] xl:flex-[0_0_34rem] border border-gray-300 p-3 sm:p-5 bg-gray-50">
                  <div class="text-brand font-bold mb-3">bar chart</div>
                  <p class="text-xs text-gray-500 mb-3 leading-relaxed">Compare categories, rankings, or before-and-after metrics.</p>
                  <pre class="bg-white border border-gray-200 px-4 py-3 overflow-x-auto text-xs leading-relaxed mb-3"><code>/draw a stacked bar chart of traffic mix by endpoint for search, checkout, and auth with read, write, and cache miss segments</code></pre>
                  <pre class="bg-black text-white border border-black px-4 py-3 overflow-x-auto text-[9px] leading-tight"><code>
  ┌────────────────────────┐
  │Traffic mix by endpoint │
  ├────────────────────────┴─────────────────────────────────┐
  │ search    ▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▒▒▒▒▒▒▒▒▒▒░░░░░░      320 rps  │
  │ checkout  ▓▓▓▓▓▓▓▓▓▓▓▓▒▒▒▒▒▒▒▒▒▒▒▒▒▒░░░░░░░░    280 rps  │
  │ auth      ▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▓▒▒▒▒▒▒▒▒░░░░        240 rps  │
  │                                                          │
  └─▓ read   ▒ write   ░ cache miss──────────────────────────┘</code></pre>
                </div>
                <div class="min-w-0 w-full flex-[0_0_100%] snap-center sm:max-w-[30rem] sm:flex-[0_0_30rem] xl:max-w-[34rem] xl:flex-[0_0_34rem] border border-gray-300 p-3 sm:p-5 bg-gray-50">
                  <div class="text-brand font-bold mb-3">ascii drawing</div>
                  <p class="text-xs text-gray-500 mb-3 leading-relaxed">Create title art, mascots, and small terminal-friendly illustrations.</p>
                  <pre class="bg-white border border-gray-200 px-4 py-3 overflow-x-auto text-xs leading-relaxed mb-3"><code>/draw a small cute robot as ASCII art with a square head, bright eyes, tiny arms, little legs, and a friendly expression</code></pre>
                  <pre class="bg-black text-white border border-black px-4 py-3 overflow-x-auto text-[9px] leading-tight"><code>
           ●
           │
     ╭─────┴────╮
     │  ^   ^   │
     │    -     │
     ╰──────────╯
     ╭───────────╮
     │           │
╭──╮ │  ♥ BEEP   │ ╭──╮
│o=│ │  BOOP! ♥  │ │=o│
╰──╯ │           │ ╰──╯
     ╰─┬──┬─┬──┬─╯
       │| │ │| │
       └──┘ └──┘</code></pre>
                </div>
                <div class="min-w-0 w-full flex-[0_0_100%] snap-center sm:max-w-[30rem] sm:flex-[0_0_30rem] xl:max-w-[34rem] xl:flex-[0_0_34rem] border border-gray-300 p-3 sm:p-5 bg-gray-50">
                  <div class="text-brand font-bold mb-3">flow chart</div>
                  <p class="text-xs text-gray-500 mb-3 leading-relaxed">Show ordered steps, branching, retries, and workflow state changes.</p>
                  <pre class="bg-white border border-gray-200 px-4 py-3 overflow-x-auto text-xs leading-relaxed mb-3"><code>/draw a flow chart for request validation, retry on fix, then processing and done</code></pre>
                  <pre class="bg-black text-white border border-black px-4 py-3 overflow-x-auto text-[9px] leading-tight"><code>



  ╭─────────╮       ╭──────────╮       ╭─────────╮       ╭──────╮
  │ Request ├───────▶ Validate ├──ok───▶ Process ├───────▶ Done │
  ╰─────────╯       ╰─────┬────╯       ╰────▲────╯       ╰──────╯
                          │                 │
                        fix                 │
                        │                   │
                        │                   │
                    ╭───▼───╮               │
                    │ Retry ├───────────────┘
                    ╰───────╯</code></pre>
                </div>
              </div>
                </div>
                <div class="mt-5 flex items-center justify-center gap-2" data-draw-carousel-dots aria-label="Skill example navigation"></div>
              </div>
          </div>

          <div class="pt-12">
            <div class="mb-12">
              <h3 class="inline-block text-2xl font-mono font-bold border border-dashed border-gray-300 px-4 py-2 bg-white">Why It Feels So Good</h3>
            </div>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-6 text-center">
              <div class="border border-gray-300 bg-white p-8">
                <div class="font-mono text-sm font-bold text-brand mb-2 tracking-wide">.txt .png .svg</div>
                <h3 class="inline-block text-lg font-mono font-semibold mb-3 border border-dashed border-gray-300 px-3 py-1">Multiple Export Formats</h3>
                <p class="text-sm text-gray-500 leading-relaxed">Export as plain ASCII text, PNG, or SVG. You can also copy diagrams straight to your clipboard.</p>
              </div>
              <div class="border border-gray-300 bg-white p-8">
                <div class="font-mono text-sm font-bold text-brand mb-2 tracking-wide">&#9638; &#9637; &#9636;</div>
                <h3 class="inline-block text-lg font-mono font-semibold mb-3 border border-dashed border-gray-300 px-3 py-1">Layers & Grouping</h3>
                <p class="text-sm text-gray-500 leading-relaxed">Organize shapes with a hierarchical layer panel. Toggle visibility, lock layers, reorder with drag-and-drop, and group with &#8984;G.</p>
              </div>
              <div class="border border-gray-300 bg-white p-8">
                <div class="font-mono text-sm font-bold text-brand mb-2 tracking-wide">DSL ↔ ASCII</div>
                <h3 class="inline-block text-lg font-mono font-semibold mb-3 border border-dashed border-gray-300 px-3 py-1">Token-Friendly DSL</h3>
                <p class="text-sm text-gray-500 leading-relaxed">A lightweight, human-readable language for describing diagrams. Token-efficient and easy for LLMs to generate.</p>
              </div>
              <div class="border border-gray-300 bg-white p-8">
                <div class="font-mono text-sm font-bold text-brand mb-2 tracking-wide">&#8984; &#8997; &#8679;</div>
                <h3 class="inline-block text-lg font-mono font-semibold mb-3 border border-dashed border-gray-300 px-3 py-1">Native macOS</h3>
                <p class="text-sm text-gray-500 leading-relaxed">Built with SwiftUI. Fast, lightweight, and feels right at home on your Mac.</p>
              </div>
            </div>

          </div>
        </div>
      </div>
    </section>

    <section id="quickstart" class="py-24 px-6">
      <div class="max-w-3xl mx-auto border border-gray-300 bg-white p-4 sm:p-10">
        <div class="font-mono text-sm font-bold text-brand mb-2 tracking-wide">quickstart</div>
        <h2 class="inline-block text-2xl font-mono font-bold mb-12 border border-dashed border-gray-300 px-4 py-2">Get Running</h2>
        <ol class="space-y-8 font-mono text-sm">
          <li class="flex gap-3 sm:gap-4">
            <span class="text-brand font-bold shrink-0">1.</span>
            <div class="min-w-0">
              <p class="font-semibold mb-1">Download YuzuDraw</p>
              <a href="https://github.com/agavra/yuzudraw/releases/latest/download/YuzuDraw-universal.dmg" class="inline-block px-8 py-3.5 bg-black text-white font-semibold rounded-none shadow-sm hover:bg-brand-light hover:-translate-y-0.5 transition-all duration-200">
                <svg class="inline-block w-4 h-4 -mt-1.5 mr-1.5 align-middle" viewBox="0 0 814 1000" fill="currentColor"><path d="M788.1 340.9c-5.8 4.5-108.2 62.2-108.2 190.5 0 148.4 130.3 200.9 134.2 202.2-.6 3.2-20.7 71.9-68.7 141.9-42.8 61.6-87.5 123.1-155.5 123.1s-85.5-39.5-164-39.5c-76.5 0-103.7 40.8-165.9 40.8s-105.6-57.8-155.5-127.4c-58.4-81.8-105.9-209.2-105.9-330.8 0-194.3 126.4-297.5 250.8-297.5 66.1 0 121.2 43.4 162.7 43.4 39.5 0 101.1-46 176.3-46 28.5 0 130.9 2.6 198.3 99.2zm-234-181.5c31.1-36.9 53.1-88.1 53.1-139.3 0-7.1-.6-14.3-1.9-20.1-50.6 1.9-110.8 33.7-147.1 75.8-28.5 32.4-55.1 83.6-55.1 135.5 0 7.8.7 15.6 1.3 18.1 2.6.5 6.5.5 10.4.5 45.9 0 104-30.4 139.3-70.5z"/></svg>
                Download for Mac
              </a>
            </div>
          </li>
          <li class="flex gap-3 sm:gap-4">
            <span class="text-brand font-bold shrink-0">2.</span>
            <div class="min-w-0">
              <p class="font-semibold mb-1">Install the CLI + skill</p>
              <div class="relative border border-gray-200 bg-gray-50">
                <button
                  type="button"
                  class="copy-button"
                  data-copy-button
                  data-copy-text="curl -fsSL https://www.yuzudraw.com/install.sh | sh"
                  data-copy-default-label="Copy install command to clipboard"
                  data-copy-success-label="Copied install command"
                  data-copy-failed-label="Copy failed"
                  aria-label="Copy install command to clipboard"
                  title="Copy install command to clipboard"
                >
                  <svg
                    aria-hidden="true"
                    class="copy-button__icon copy-button__icon--copy"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.8"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  >
                    <rect x="9" y="9" width="11" height="11" rx="2"></rect>
                    <path d="M6 15H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v1"></path>
                  </svg>
                  <svg
                    aria-hidden="true"
                    class="copy-button__icon copy-button__icon--check"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  >
                    <path d="M20 6 9 17l-5-5"></path>
                  </svg>
                  <span class="sr-only">Copy install command to clipboard</span>
                </button>
                <pre class="px-3 py-3 pr-12 overflow-x-auto text-[11px] leading-relaxed sm:px-4 sm:pr-14 sm:text-xs"><code class="whitespace-pre-wrap break-all">curl -fsSL https://www.yuzudraw.com/install.sh | sh</code></pre>
              </div>
            </div>
          </li>
          <li class="flex gap-3 sm:gap-4">
            <span class="text-brand font-bold shrink-0">3.</span>
            <div class="min-w-0">
              <p class="font-semibold mb-1">Prompt your agent</p>
              <pre class="bg-gray-50 border border-gray-200 px-3 py-3 overflow-x-auto text-[11px] leading-relaxed sm:px-4 sm:text-xs"><code class="whitespace-pre-wrap break-words">/draw a cute robot ascii art</code></pre>
            </div>
          </li>
          <li class="flex gap-3 sm:gap-4">
            <span class="text-brand font-bold shrink-0">4.</span>
            <div class="min-w-0">
              <p class="font-semibold mb-1">Refine it on the canvas</p>
              <pre class="bg-gray-50 border border-gray-200 px-3 py-3 overflow-x-auto text-[11px] leading-relaxed sm:px-4 sm:text-xs"><code class="whitespace-pre-wrap break-words">Open the generated .yuzudraw file in the app and keep editing visually.</code></pre>
            </div>
          </li>
        </ol>
        <div class="mt-10 pt-6 border-t border-gray-200 text-center">
          <a href="https://github.com/sponsors/agavra" target="_blank" rel="noopener" class="inline-block border border-gray-300 bg-white px-4 py-2 font-mono text-sm text-gray-500 transition-colors hover:border-brand hover:text-brand">
            &#9829; Sponsor YuzuDraw
          </a>
          <p class="mt-3 text-xs text-gray-400 leading-relaxed">
            Sponsorship helps cover ongoing development and the Apple Developer membership for releases.
          </p>
        </div>
      </div>
    </section>

    <script type="module" is:inline>
      for (const trigger of document.querySelectorAll('[data-scroll-to]')) {
        trigger.addEventListener('click', (event) => {
          const id = trigger.getAttribute('data-scroll-to');
          if (!id) return;

          const target = document.getElementById(id);
          if (!target) return;

          event.preventDefault();
          target.scrollIntoView({
            behavior: 'smooth',
            block: 'start',
          });
        });
      }

      for (const button of document.querySelectorAll('[data-copy-button]')) {
        button.addEventListener('click', async () => {
          const text = button.getAttribute('data-copy-text');
          if (!text) return;

          const defaultLabel = button.getAttribute('data-copy-default-label') ?? 'Copy to clipboard';
          const successLabel = button.getAttribute('data-copy-success-label') ?? 'Copied';
          const failedLabel = button.getAttribute('data-copy-failed-label') ?? 'Copy failed';

          const resetLabel = () => {
            button.dataset.copyState = 'idle';
            button.setAttribute('aria-label', defaultLabel);
            button.setAttribute('title', defaultLabel);
          };

          try {
            await navigator.clipboard.writeText(text);
            button.dataset.copyState = 'success';
            button.setAttribute('aria-label', successLabel);
            button.setAttribute('title', successLabel);
            window.setTimeout(resetLabel, 1500);
          } catch {
            button.dataset.copyState = 'error';
            button.setAttribute('aria-label', failedLabel);
            button.setAttribute('title', failedLabel);
            window.setTimeout(resetLabel, 2000);
          }
        });
      }

      for (const root of document.querySelectorAll('[data-draw-carousel]')) {
        const viewport = root.querySelector('[data-draw-carousel-viewport]');
        const container = root.querySelector('[data-draw-carousel-container]');
        const dots = root.querySelector('[data-draw-carousel-dots]');
        if (!viewport || !container || !dots) continue;

        const slides = [...container.children];

        const updateDots = () => {
          const viewportRect = viewport.getBoundingClientRect();
          const viewportCenter = viewportRect.left + viewportRect.width / 2;
          let activeIndex = 0;
          let closestDistance = Number.POSITIVE_INFINITY;

          slides.forEach((slide, index) => {
            const slideRect = slide.getBoundingClientRect();
            const slideCenter = slideRect.left + slideRect.width / 2;
            const distance = Math.abs(slideCenter - viewportCenter);
            if (distance < closestDistance) {
              closestDistance = distance;
              activeIndex = index;
            }
          });

          [...dots.children].forEach((dot, index) => {
            dot.setAttribute('aria-current', index === activeIndex ? 'true' : 'false');
            dot.className = index === activeIndex
              ? 'h-2.5 w-6 rounded-full bg-gray-900 transition-all'
              : 'h-2.5 w-2.5 rounded-full bg-gray-300 transition-all hover:bg-gray-500';
          });
        };

        const centerSlide = (slide) => {
          slide.scrollIntoView({
            behavior: 'smooth',
            block: 'nearest',
            inline: 'center',
          });
        };

        dots.innerHTML = '';
        slides.forEach((slide, index) => {
          const dot = document.createElement('button');
          dot.type = 'button';
          dot.ariaLabel = `Go to example ${index + 1}`;
          dot.addEventListener('click', () => centerSlide(slide));
          dots.appendChild(dot);
        });

        viewport.addEventListener('scroll', updateDots, { passive: true });
        viewport.addEventListener('wheel', (event) => {
          if (Math.abs(event.deltaY) <= Math.abs(event.deltaX)) return;

          const maxScrollLeft = viewport.scrollWidth - viewport.clientWidth;
          const nextScrollLeft = viewport.scrollLeft + event.deltaY;
          const canScrollHorizontally =
            (event.deltaY < 0 && viewport.scrollLeft > 0) ||
            (event.deltaY > 0 && viewport.scrollLeft < maxScrollLeft);

          if (!canScrollHorizontally || nextScrollLeft < 0 || nextScrollLeft > maxScrollLeft) {
            return;
          }

          event.preventDefault();
          viewport.scrollBy({ left: event.deltaY, behavior: 'auto' });
        }, { passive: false });
        window.addEventListener('resize', updateDots);

        updateDots();
      }
    </script>

    <!-- Footer -->
    <footer class="py-10 px-6 flex justify-between items-center text-sm font-mono text-gray-400 border-t border-gray-100">
      <span>made with &#9829; in CA</span>
      <span>&copy; 2025 YuzuDraw</span>
    </footer>
  </main>
</Layout>
