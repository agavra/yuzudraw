---
import Layout from '../layouts/Layout.astro';
---

<Layout title="YuzuDraw — ASCII Diagram Editor for macOS">
  <!-- Topbar -->
  <nav class="sticky top-0 z-50 bg-white/80 backdrop-blur-lg border-b border-gray-100">
    <div class="px-6 h-14 flex items-center">
      <a href="/" class="flex items-center gap-2 text-gray-700 no-underline text-xl tracking-tight">
        <img src="/logo.svg" alt="" class="w-7 h-7 rounded-md" />
        <span><span class="font-extralight">yuzu</span><span class="font-bold">draw</span></span>
      </a>
    </div>
  </nav>

  <main>
    <!-- Hero -->
    <section class="pt-24 pb-32 text-center px-6">
      <div class="max-w-3xl mx-auto">
        <h1 class="inline-block border-2 border-gray-900 px-8 py-4 text-[clamp(2rem,5vw,3.75rem)] font-mono font-bold tracking-tight leading-[1.05] mb-6 whitespace-nowrap">
          beautiful ascii diagrams
        </h1>
        <p class="text-lg text-gray-500 max-w-2xl mx-auto mb-10 leading-relaxed">
          A MacOS native diagram editor with a built-in MCP server.
          Let Claude generate your diagrams, then refine them on a visual canvas.
        </p>
        <a href="#waitlist" class="inline-block px-8 py-3.5 bg-black text-white font-semibold rounded-none shadow-sm hover:bg-brand-light hover:-translate-y-0.5 transition-all duration-200">
          Join the Waitlist
        </a>
      </div>
    </section>

    <!-- Feature sections with screenshots -->
    <section class="pb-24 px-6">
      <div class="max-w-5xl mx-auto flex flex-col gap-32">

        <!-- MCP Server -->
        <div class="flex flex-col md:flex-row items-center gap-10">
          <div class="md:w-1/3 shrink-0">
            <div class="font-mono text-sm font-bold text-brand mb-2 tracking-wide">&gt;=&gt;</div>
            <h3 class="inline-block text-xl font-mono font-semibold mb-3 border border-dashed border-gray-300 px-3 py-1">Built-in MCP Server</h3>
            <p class="text-sm text-gray-500 leading-relaxed">Claude connects directly to YuzuDraw. Describe your architecture and get a diagram — no copy-paste needed.</p>
          </div>
          <div class="md:w-2/3 rounded-xl overflow-hidden">
            <img src="/screenshot-claude.png" alt="Claude generating a diagram via MCP" class="block w-full h-auto" />
          </div>
        </div>

        <!-- Visual Canvas -->
        <div class="flex flex-col md:flex-row-reverse items-center gap-10">
          <div class="md:w-1/3 shrink-0">
            <div class="font-mono text-sm font-bold text-brand mb-2 tracking-wide">&#8598; &#9633; &#8600;</div>
            <h3 class="inline-block text-xl font-mono font-semibold mb-3 border border-dashed border-gray-300 px-3 py-1">Visual Canvas</h3>
            <p class="text-sm text-gray-500 leading-relaxed">Drag, resize, and connect shapes on an infinite canvas. Organize with layers and groups. Refine what AI generates, or start from scratch.</p>
          </div>
          <div class="md:w-2/3 rounded-xl overflow-hidden">
            <img src="/screenshot-overview.png" alt="YuzuDraw visual canvas" class="block w-full h-auto" />
          </div>
        </div>

      </div>
    </section>

    <!-- Secondary features grid -->
    <section class="py-24 px-6 border-t border-gray-100">
      <div class="max-w-3xl mx-auto grid grid-cols-1 sm:grid-cols-2 gap-12 text-center">
        <div>
          <div class="font-mono text-sm font-bold text-brand mb-2 tracking-wide">.txt .png .svg</div>
          <h3 class="inline-block text-lg font-mono font-semibold mb-3 border border-dashed border-gray-300 px-3 py-1">Multiple Export Formats</h3>
          <p class="text-sm text-gray-500 leading-relaxed">Export as plain ASCII text, PNG, or SVG — or copy straight to your clipboard.</p>
        </div>
        <div>
          <div class="font-mono text-sm font-bold text-brand mb-2 tracking-wide">&#8984; &#8997; &#8679;</div>
          <h3 class="inline-block text-lg font-mono font-semibold mb-3 border border-dashed border-gray-300 px-3 py-1">Native macOS</h3>
          <p class="text-sm text-gray-500 leading-relaxed">Built with SwiftUI. Fast, lightweight, and feels right at home on your Mac.</p>
        </div>
      </div>
    </section>

    <!-- Waitlist -->
    <section class="py-24 px-6 bg-gray-50 border-t border-gray-100" id="waitlist">
      <div class="max-w-md mx-auto text-center">
        <h2 class="text-3xl font-mono font-bold tracking-tight mb-4">Get early access</h2>
        <p class="text-gray-500 mb-10">
          YuzuDraw is currently in development. Sign up to be notified when it's ready.
        </p>
        <form id="waitlist-form">
          <div class="flex flex-col sm:flex-row gap-2">
            <input
              type="email"
              name="email"
              placeholder="you@example.com"
              required
              autocomplete="email"
              class="flex-1 px-4 py-3 text-base bg-white border border-gray-200 rounded-none outline-none focus:border-brand transition-colors"
            />
            <button type="submit" class="px-6 py-3 text-base font-semibold bg-brand text-gray-900 rounded-none hover:bg-brand-light hover:-translate-y-0.5 transition-all duration-200 cursor-pointer whitespace-nowrap disabled:opacity-50 disabled:cursor-not-allowed disabled:translate-y-0">
              Join Waitlist
            </button>
          </div>
          <!-- Honeypot -->
          <input type="text" name="website" autocomplete="off" tabindex="-1" aria-hidden="true" class="absolute -left-[9999px] opacity-0 h-0 w-0 pointer-events-none" />
          <p class="mt-3 text-sm min-h-[1.4em]" id="form-status"></p>
        </form>
      </div>
    </section>

    <!-- Footer -->
    <footer class="py-10 px-6 flex justify-between items-center text-sm font-mono text-gray-400 border-t border-gray-100">
      <span>made with &#9829; in CA</span>
      <span>&copy; 2025 YuzuDraw</span>
    </footer>
  </main>
</Layout>

<script>
  const APPS_SCRIPT_URL = 'https://script.google.com/macros/s/AKfycbyYWolDZnabjc4jIjh1yVWhcEAVVUpIbmPKVG4C3EPlY4LXLTErG_ns5qQ8NJfkurkb/exec';

  const EMAIL_RE = /^[^\s@]+@[^\s@]+\.[^\s@]{2,}$/;

  const form = document.getElementById('waitlist-form') as HTMLFormElement;
  const status = document.getElementById('form-status')!;

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    const btn = form.querySelector('button')!;
    const data = new FormData(form);
    const email = (data.get('email') as string).trim();
    const honeypot = data.get('website') as string;

    if (honeypot) {
      status.className = 'mt-3 text-sm min-h-[1.4em] text-green-500';
      status.textContent = "You're on the list! We'll be in touch.";
      form.reset();
      return;
    }

    if (!EMAIL_RE.test(email)) {
      status.className = 'mt-3 text-sm min-h-[1.4em] text-red-400';
      status.textContent = 'Please enter a valid email address.';
      return;
    }

    btn.disabled = true;
    btn.textContent = 'Submitting...';
    status.className = 'mt-3 text-sm min-h-[1.4em]';
    status.textContent = '';

    try {
      await fetch(APPS_SCRIPT_URL, {
        method: 'POST',
        mode: 'no-cors',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
        body: `email=${encodeURIComponent(email)}`,
      });
      status.className = 'mt-3 text-sm min-h-[1.4em] text-green-500';
      status.textContent = "You're on the list! We'll be in touch.";
      form.reset();
    } catch {
      status.className = 'mt-3 text-sm min-h-[1.4em] text-red-400';
      status.textContent = 'Something went wrong. Please try again.';
    } finally {
      btn.disabled = false;
      btn.textContent = 'Join Waitlist';
    }
  });
</script>
