---
import Layout from '../layouts/Layout.astro';
---

<Layout title="YuzuDraw — ASCII Diagram Editor for macOS">
  <main>
    <!-- Hero -->
    <section class="hero">
      <div class="container">
        <img src="/logo.svg" alt="YuzuDraw" class="hero-logo" width="80" height="80" />
        <div class="badge mono">Native macOS app</div>
        <h1>Draw ASCII diagrams<br /><span class="highlight">visually.</span></h1>
        <p class="subtitle">
          YuzuDraw is a native macOS editor for creating beautiful ASCII diagrams.
          Design on a visual canvas, export as plain text. Perfect for docs, code comments, and READMEs.
        </p>
        <a href="#waitlist" class="cta-button">Join the Waitlist</a>
      </div>
    </section>

    <!-- Screenshot -->
    <section class="screenshot-section">
      <div class="container">
        <div class="screenshot-wrapper">
          <img src="/screenshot-overview.png" alt="YuzuDraw — ASCII diagram editor for macOS" width="1920" height="1080" />
        </div>
      </div>
    </section>

    <!-- Features -->
    <section class="features">
      <div class="container">
        <div class="features-grid">
          <div class="feature">
            <div class="feature-icon mono">+---+</div>
            <h3>Visual Canvas</h3>
            <p>Drag, resize, and connect shapes on an infinite canvas. No more counting characters.</p>
          </div>
          <div class="feature">
            <div class="feature-icon mono">--&gt;</div>
            <h3>Smart Arrows</h3>
            <p>Arrows snap to shapes and route automatically. Move things around and connections follow.</p>
          </div>
          <div class="feature">
            <div class="feature-icon mono">.txt</div>
            <h3>Plain Text Output</h3>
            <p>Export as plain ASCII text that you can paste anywhere — GitHub, Slack, code comments, docs.</p>
          </div>
          <div class="feature">
            <div class="feature-icon mono">⌘</div>
            <h3>Native macOS</h3>
            <p>Built with SwiftUI. Fast, lightweight, and feels right at home on your Mac.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ASCII art divider -->
    <div class="ascii-divider mono">
      <pre>{`  +----------+     +----------+     +----------+
  |  Design  |---->|  Export  |---->|  Paste   |
  +----------+     +----------+     +----------+`}</pre>
    </div>

    <!-- Waitlist -->
    <section class="waitlist" id="waitlist">
      <div class="container">
        <h2>Get early access</h2>
        <p class="waitlist-subtitle">
          YuzuDraw is currently in development. Sign up to be notified when it's ready.
        </p>
        <div class="form-container">
          <form id="waitlist-form" class="waitlist-form">
            <div class="input-group">
              <input
                type="email"
                name="email"
                placeholder="you@example.com"
                required
                autocomplete="email"
              />
              <button type="submit">Join Waitlist</button>
            </div>
            <!-- Honeypot — hidden from humans, bots will fill it -->
            <input type="text" name="website" autocomplete="off" tabindex="-1" aria-hidden="true" class="hp-field" />
            <p class="form-status" id="form-status"></p>
          </form>
          <p class="form-note">
            Or email <a href="mailto:hello@yuzudraw.com">hello@yuzudraw.com</a> to get on the list.
          </p>
        </div>
      </div>
    </section>

    <!-- Footer -->
    <footer>
      <div class="container">
        <p class="mono">&copy; 2025 YuzuDraw</p>
      </div>
    </footer>
  </main>
</Layout>

<style>
  .container {
    max-width: 960px;
    margin: 0 auto;
    padding: 0 24px;
  }

  /* Hero */
  .hero {
    padding: 120px 0 60px;
    text-align: center;
  }

  .hero-logo {
    margin-bottom: 24px;
    border-radius: 16px;
  }

  .badge {
    display: inline-block;
    padding: 6px 16px;
    border: 1px solid #ccc;
    border-radius: 20px;
    font-size: 0.8rem;
    color: #666;
    margin-bottom: 24px;
    letter-spacing: 0.02em;
  }

  h1 {
    font-size: clamp(2.5rem, 6vw, 4rem);
    font-weight: 700;
    line-height: 1.1;
    margin-bottom: 24px;
    letter-spacing: -0.02em;
  }

  .highlight {
    color: #3d8c40;
  }

  .subtitle {
    font-size: 1.15rem;
    color: #555;
    max-width: 560px;
    margin: 0 auto 40px;
    line-height: 1.6;
  }

  .cta-button {
    display: inline-block;
    padding: 14px 32px;
    background: #3d8c40;
    color: #fff;
    font-weight: 600;
    font-size: 1rem;
    border-radius: 8px;
    text-decoration: none;
    transition: background 0.2s, transform 0.2s;
  }

  .cta-button:hover {
    background: #4a9e4d;
    transform: translateY(-1px);
  }

  /* Screenshot */
  .screenshot-section {
    padding: 40px 0 80px;
  }

  .screenshot-wrapper {
    border-radius: 12px;
    overflow: hidden;
    border: 1px solid #ddd;
    box-shadow: 0 24px 80px rgba(0, 0, 0, 0.1);
  }

  .screenshot-wrapper img {
    display: block;
    width: 100%;
    height: auto;
  }

  /* Features */
  .features {
    padding: 80px 0;
  }

  .features-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 48px 40px;
  }

  @media (max-width: 640px) {
    .features-grid {
      grid-template-columns: 1fr;
    }
  }

  .feature-icon {
    font-size: 1.2rem;
    color: #3d8c40;
    margin-bottom: 12px;
  }

  .feature h3 {
    font-size: 1.1rem;
    font-weight: 600;
    margin-bottom: 8px;
  }

  .feature p {
    color: #666;
    line-height: 1.6;
    font-size: 0.95rem;
  }

  /* ASCII divider */
  .ascii-divider {
    text-align: center;
    padding: 60px 0;
    color: #999;
    font-size: 0.85rem;
    overflow-x: auto;
  }

  /* Waitlist */
  .waitlist {
    padding: 80px 0;
    text-align: center;
  }

  .waitlist h2 {
    font-size: 2rem;
    font-weight: 700;
    margin-bottom: 16px;
    letter-spacing: -0.01em;
  }

  .waitlist-subtitle {
    color: #666;
    font-size: 1.05rem;
    margin-bottom: 40px;
  }

  .form-container {
    max-width: 480px;
    margin: 0 auto;
  }

  .input-group {
    display: flex;
    gap: 8px;
  }

  @media (max-width: 480px) {
    .input-group {
      flex-direction: column;
    }
  }

  .input-group input {
    flex: 1;
    padding: 14px 18px;
    font-size: 1rem;
    font-family: inherit;
    background: #fff;
    border: 1px solid #ccc;
    border-radius: 8px;
    color: #1a1a1a;
    outline: none;
    transition: border-color 0.2s;
  }

  .input-group input:focus {
    border-color: #3d8c40;
  }

  .input-group input::placeholder {
    color: #999;
  }

  .input-group button {
    padding: 14px 28px;
    font-size: 1rem;
    font-family: inherit;
    font-weight: 600;
    background: #3d8c40;
    color: #fff;
    border: none;
    border-radius: 8px;
    cursor: pointer;
    white-space: nowrap;
    transition: background 0.2s, transform 0.2s;
  }

  .input-group button:hover {
    background: #4a9e4d;
    transform: translateY(-1px);
  }

  .input-group button:disabled {
    opacity: 0.6;
    cursor: not-allowed;
    transform: none;
  }

  .form-status {
    margin-top: 12px;
    font-size: 0.9rem;
    min-height: 1.4em;
  }

  .form-status.success {
    color: #4ade80;
  }

  .form-status.error {
    color: #f87171;
  }

  .form-note {
    margin-top: 16px;
    color: #888;
    font-size: 0.9rem;
  }

  .form-note a {
    color: #3d8c40;
    text-decoration: none;
  }

  .form-note a:hover {
    text-decoration: underline;
  }

  .hp-field {
    position: absolute;
    left: -9999px;
    opacity: 0;
    height: 0;
    width: 0;
    pointer-events: none;
  }

  /* Footer */
  footer {
    padding: 40px 0;
    text-align: center;
    color: #999;
    font-size: 0.85rem;
    border-top: 1px solid #ddd;
  }
</style>

<script>
  const APPS_SCRIPT_URL = 'https://script.google.com/macros/s/AKfycbyYWolDZnabjc4jIjh1yVWhcEAVVUpIbmPKVG4C3EPlY4LXLTErG_ns5qQ8NJfkurkb/exec';

  const EMAIL_RE = /^[^\s@]+@[^\s@]+\.[^\s@]{2,}$/;

  const form = document.getElementById('waitlist-form') as HTMLFormElement;
  const status = document.getElementById('form-status')!;

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    const btn = form.querySelector('button')!;
    const data = new FormData(form);
    const email = (data.get('email') as string).trim();
    const honeypot = data.get('website') as string;

    // Honeypot check — silently "succeed" so bots don't retry
    if (honeypot) {
      status.className = 'form-status success';
      status.textContent = "You're on the list! We'll be in touch.";
      form.reset();
      return;
    }

    // Email validation
    if (!EMAIL_RE.test(email)) {
      status.className = 'form-status error';
      status.textContent = 'Please enter a valid email address.';
      return;
    }

    btn.disabled = true;
    btn.textContent = 'Submitting...';
    status.className = 'form-status';
    status.textContent = '';

    try {
      await fetch(APPS_SCRIPT_URL, {
        method: 'POST',
        mode: 'no-cors',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
        body: `email=${encodeURIComponent(email)}`,
      });
      status.className = 'form-status success';
      status.textContent = "You're on the list! We'll be in touch.";
      form.reset();
    } catch {
      status.className = 'form-status error';
      status.textContent = 'Something went wrong. Please try again.';
    } finally {
      btn.disabled = false;
      btn.textContent = 'Join Waitlist';
    }
  });
</script>
