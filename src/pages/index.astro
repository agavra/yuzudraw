---
import Layout from '../layouts/Layout.astro';

const res = await fetch('https://api.github.com/repos/agavra/yuzudraw');
const data = await res.json();
const stars = (data.stargazers_count ?? 0).toLocaleString();
---

<Layout title="YuzuDraw">
  <!-- Topbar -->
  <nav class="sticky top-0 z-50 bg-white/80 backdrop-blur-lg border-b border-gray-100">
    <div class="px-6 h-14 flex items-center justify-between">
      <a href="/" class="flex items-center gap-2 text-gray-700 no-underline text-xl tracking-tight">
        <img src="/yuzudraw-icon.svg" alt="" class="h-7" />
        <span><span class="font-extralight">yuzu</span><span class="font-bold">draw</span></span>
      </a>
      <a href="https://github.com/agavra/yuzudraw" target="_blank" rel="noopener" class="flex items-center gap-1.5 text-gray-400 hover:text-gray-900 border border-gray-200 rounded-full px-2.5 py-1 transition-colors" aria-label="GitHub">
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
          <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
        </svg>
        <span class="text-xs flex items-center gap-0.5">
          <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 16 16">
            <path d="M8 .25a.75.75 0 01.673.418l1.882 3.815 4.21.612a.75.75 0 01.416 1.279l-3.046 2.97.719 4.192a.75.75 0 01-1.088.791L8 12.347l-3.766 1.98a.75.75 0 01-1.088-.79l.72-4.194L.818 6.374a.75.75 0 01.416-1.28l4.21-.611L7.327.668A.75.75 0 018 .25z"/>
          </svg>
          {stars}
        </span>
      </a>
    </div>
  </nav>

  <main>
    <!-- Hero -->
    <section class="pt-24 pb-32 text-center px-6">
      <div class="max-w-3xl mx-auto">
        <h1 class="inline-block border-2 border-gray-900 px-8 py-4 text-[clamp(2rem,5vw,3.75rem)] font-mono font-bold tracking-tight leading-[1.05] mb-6 whitespace-nowrap">
          beautiful ascii diagrams
        </h1>
        <p class="text-lg text-gray-500 max-w-2xl mx-auto mb-10 leading-relaxed">
          A MacOS native diagram editor with an agent skill.
          Let Codex or Claude generate your diagrams, then refine them on a visual canvas.
        </p>
        <a href="https://github.com/agavra/yuzudraw/releases/latest/download/YuzuDraw-universal.dmg" class="inline-block px-8 py-3.5 bg-black text-white font-semibold rounded-none shadow-sm hover:bg-brand-light hover:-translate-y-0.5 transition-all duration-200">
          <svg class="inline-block w-4 h-4 -mt-1.5 mr-1.5 align-middle" viewBox="0 0 814 1000" fill="currentColor"><path d="M788.1 340.9c-5.8 4.5-108.2 62.2-108.2 190.5 0 148.4 130.3 200.9 134.2 202.2-.6 3.2-20.7 71.9-68.7 141.9-42.8 61.6-87.5 123.1-155.5 123.1s-85.5-39.5-164-39.5c-76.5 0-103.7 40.8-165.9 40.8s-105.6-57.8-155.5-127.4c-58.4-81.8-105.9-209.2-105.9-330.8 0-194.3 126.4-297.5 250.8-297.5 66.1 0 121.2 43.4 162.7 43.4 39.5 0 101.1-46 176.3-46 28.5 0 130.9 2.6 198.3 99.2zm-234-181.5c31.1-36.9 53.1-88.1 53.1-139.3 0-7.1-.6-14.3-1.9-20.1-50.6 1.9-110.8 33.7-147.1 75.8-28.5 32.4-55.1 83.6-55.1 135.5 0 7.8.7 15.6 1.3 18.1 2.6.5 6.5.5 10.4.5 45.9 0 104-30.4 139.3-70.5z"/></svg>
          Download for Mac
        </a>
      </div>
    </section>

    <!-- Feature sections with screenshots -->
    <section class="pb-24 px-6">
      <div class="max-w-5xl mx-auto flex flex-col gap-32">

        <!-- Human-in-the-Loop Editing -->
        <div class="flex flex-col md:flex-row items-center gap-10">
          <div class="md:w-1/3 shrink-0">
            <div class="font-mono text-sm font-bold text-brand mb-2 tracking-wide">&gt;=&gt;</div>
            <h3 class="inline-block text-xl font-mono font-semibold mb-3 border border-dashed border-gray-300 px-3 py-1">Human-in-the-Loop Editing</h3>
            <p class="text-sm text-gray-500 leading-relaxed">Use AI to generate diagrams with a custom skill, CLI, and token-efficient DSL, then refine them by hand on the canvas.</p>
          </div>
          <div class="md:w-2/3 rounded-xl overflow-hidden">
            <img src="/screenshot-claude.png" alt="Agent generating a diagram via YuzuDraw CLI" class="block w-full h-auto" />
          </div>
        </div>

        <!-- Visual Canvas -->
        <div class="flex flex-col md:flex-row-reverse items-center gap-10">
          <div class="md:w-1/3 shrink-0">
            <div class="font-mono text-sm font-bold text-brand mb-2 tracking-wide">&#8598; &#9633; &#8600;</div>
            <h3 class="inline-block text-xl font-mono font-semibold mb-3 border border-dashed border-gray-300 px-3 py-1">Visual Canvas</h3>
            <p class="text-sm text-gray-500 leading-relaxed">Drag, resize, and connect shapes on an infinite canvas. Refine what AI generates or start from scratch.</p>
          </div>
          <div class="md:w-2/3 rounded-xl overflow-hidden">
            <img src="/screenshot-overview.png" alt="YuzuDraw visual canvas" class="block w-full h-auto" />
          </div>
        </div>

      </div>
    </section>

    <!-- Secondary features grid -->
    <section class="relative border-t border-gray-100 overflow-hidden">
      <div class="absolute inset-0 canvas-grid"></div>
      <div class="relative py-28 px-6">
          <div class="max-w-4xl mx-auto grid grid-cols-1 sm:grid-cols-2 gap-x-20 gap-y-16 text-center">
            <div class="border border-gray-300 bg-white p-8">
              <div class="font-mono text-sm font-bold text-brand mb-2 tracking-wide">.txt .png .svg</div>
              <h3 class="inline-block text-lg font-mono font-semibold mb-3 border border-dashed border-gray-300 px-3 py-1">Multiple Export Formats</h3>
              <p class="text-sm text-gray-500 leading-relaxed">Export as plain ASCII text, PNG, or SVG. You can also copy diagrams straight to your clipboard.</p>
            </div>
            <div class="border border-gray-300 bg-white p-8">
              <div class="font-mono text-sm font-bold text-brand mb-2 tracking-wide">&#9638; &#9637; &#9636;</div>
              <h3 class="inline-block text-lg font-mono font-semibold mb-3 border border-dashed border-gray-300 px-3 py-1">Layers & Grouping</h3>
              <p class="text-sm text-gray-500 leading-relaxed">Organize shapes with a hierarchical layer panel. Toggle visibility, lock layers, reorder with drag-and-drop, and group with &#8984;G.</p>
            </div>
            <div class="border border-gray-300 bg-white p-8">
              <div class="font-mono text-sm font-bold text-brand mb-2 tracking-wide">DSL ↔ ASCII</div>
              <h3 class="inline-block text-lg font-mono font-semibold mb-3 border border-dashed border-gray-300 px-3 py-1">AI-Friendly DSL</h3>
              <p class="text-sm text-gray-500 leading-relaxed">A lightweight, human-readable language for describing diagrams. Token-efficient and easy for LLMs to generate.</p>
            </div>
            <div class="border border-gray-300 bg-white p-8">
              <div class="font-mono text-sm font-bold text-brand mb-2 tracking-wide">&#8984; &#8997; &#8679;</div>
              <h3 class="inline-block text-lg font-mono font-semibold mb-3 border border-dashed border-gray-300 px-3 py-1">Native macOS</h3>
              <p class="text-sm text-gray-500 leading-relaxed">Built with SwiftUI. Fast, lightweight, and feels right at home on your Mac.</p>
            </div>
          </div>
          </div>
      <!-- Quickstart -->
      <div class="relative pb-28 px-6">
      <div class="max-w-2xl mx-auto border border-gray-300 bg-white p-10">
        <h2 class="inline-block text-2xl font-mono font-bold mb-12 border border-dashed border-gray-300 px-4 py-2">Quickstart</h2>
        <ol class="space-y-8 font-mono text-sm">
          <li class="flex gap-4">
            <span class="text-brand font-bold shrink-0">1.</span>
            <div>
              <p class="font-semibold mb-1">Download YuzuDraw</p>
              <a href="https://github.com/agavra/yuzudraw/releases/latest/download/YuzuDraw-universal.dmg" class="inline-block px-8 py-3.5 bg-black text-white font-semibold rounded-none shadow-sm hover:bg-brand-light hover:-translate-y-0.5 transition-all duration-200">
                <svg class="inline-block w-4 h-4 -mt-1.5 mr-1.5 align-middle" viewBox="0 0 814 1000" fill="currentColor"><path d="M788.1 340.9c-5.8 4.5-108.2 62.2-108.2 190.5 0 148.4 130.3 200.9 134.2 202.2-.6 3.2-20.7 71.9-68.7 141.9-42.8 61.6-87.5 123.1-155.5 123.1s-85.5-39.5-164-39.5c-76.5 0-103.7 40.8-165.9 40.8s-105.6-57.8-155.5-127.4c-58.4-81.8-105.9-209.2-105.9-330.8 0-194.3 126.4-297.5 250.8-297.5 66.1 0 121.2 43.4 162.7 43.4 39.5 0 101.1-46 176.3-46 28.5 0 130.9 2.6 198.3 99.2zm-234-181.5c31.1-36.9 53.1-88.1 53.1-139.3 0-7.1-.6-14.3-1.9-20.1-50.6 1.9-110.8 33.7-147.1 75.8-28.5 32.4-55.1 83.6-55.1 135.5 0 7.8.7 15.6 1.3 18.1 2.6.5 6.5.5 10.4.5 45.9 0 104-30.4 139.3-70.5z"/></svg>
                Download for Mac
              </a>
            </div>
          </li>
          <li class="flex gap-4">
            <span class="text-brand font-bold shrink-0">2.</span>
            <div>
              <p class="font-semibold mb-1">Install the CLI + skills</p>
              <pre class="bg-gray-50 border border-gray-200 px-4 py-3 overflow-x-auto text-xs leading-relaxed"><code>curl -fsSL https://www.yuzudraw.com/install.sh | sh</code></pre>
            </div>
          </li>
          <li class="flex gap-4">
            <span class="text-brand font-bold shrink-0">3.</span>
            <div>
              <p class="font-semibold mb-1">Ask your agent to draw</p>
              <pre class="bg-gray-50 border border-gray-200 px-4 py-3 overflow-x-auto text-xs leading-relaxed"><code>/diagram a flowchart showing user login flow</code></pre>
            </div>
          </li>
          <li class="flex gap-4">
            <span class="text-brand font-bold shrink-0">4.</span>
            <div>
              <p class="font-semibold mb-1">Open in YuzuDraw</p>
              <pre class="bg-gray-50 border border-gray-200 px-4 py-3 overflow-x-auto text-xs leading-relaxed"><code>Open the generated .yuzudraw file in the app to refine it on the canvas.</code></pre>
            </div>
          </li>
        </ol>
        <div class="mt-10 pt-6 border-t border-gray-200 text-center">
          <a href="https://github.com/sponsors/agavra" target="_blank" rel="noopener" class="inline-block border border-gray-300 bg-white px-4 py-2 font-mono text-sm text-gray-500 transition-colors hover:border-brand hover:text-brand">
            &#9829; Sponsor YuzuDraw
          </a>
          <p class="mt-3 text-xs text-gray-400 leading-relaxed">
            Sponsorship helps cover ongoing development and the Apple Developer membership for releases.
          </p>
        </div>
      </div>
      </div>
    </section>

    <!-- Footer -->
    <footer class="py-10 px-6 flex justify-between items-center text-sm font-mono text-gray-400 border-t border-gray-100">
      <span>made with &#9829; in CA</span>
      <span>&copy; 2025 YuzuDraw</span>
    </footer>
  </main>
</Layout>
